# API base URLs for backend services
# Copy this file to .env.local and adjust as needed for your local setup

# OAuth 2.0 Authority (OIDC server)
# Leave empty to auto-detect:
#   - Dev (localhost): uses http://localhost:8085
#   - QA/Prod: uses current origin (nginx proxies OAuth endpoints)
# VITE_AUTH_AUTHORITY=http://localhost:8085

# Tenant Service
VITE_TENANT_API_URL=http://localhost:8083

# Command Service (accounts, transactions, third-parties, etc.)
VITE_COMMAND_API_URL=http://localhost:8081

# Query Service + Reporting
VITE_QUERY_API_URL=http://localhost:8082
