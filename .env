# Development environment defaults
# Note: VITE_OAUTH_AUTHORITY is intentionally omitted to enable dynamic fallback
# to window.location.origin. This allows the app to work with any hostname/IP.
# For local development with user-service on port 8085:
#   VITE_OAUTH_AUTHORITY=http://localhost:8085
VITE_COMMAND_API_URL=/api/command
VITE_QUERY_API_URL=/api/query
VITE_WORKSPACE_API_URL=/api/workspace
VITE_SUBSCRIPTION_API_URL=/api/subscription
VITE_SUBSCRIPTION_WEB_URL=http://localhost:5174
VITE_OAUTH_CLIENT_ID=accounts-ui
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/callback
VITE_OAUTH_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
